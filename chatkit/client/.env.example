# Client environment variables
# Copy this to .env and fill in your values before deploying

# URL of your deployed backend — no trailing slash
# Set this under Vercel → Project → Settings → Environment Variables
VITE_ENDPOINT=https://your-backend.up.railway.app
VITE_SERVER_ENDPOINT=https://your-backend.up.railway.app

# Hermes SDK credentials for the live demo chat on the homepage
# Get these from your project dashboard after deploying the server
VITE_HERMES_API_KEY=your_api_key_here
VITE_HERMES_SECRET=your_api_secret_here
VITE_DEMO_ROOM_ID=your_demo_room_id_here
